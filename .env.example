# NVIDIA API (free at https://build.nvidia.com)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# Groq AI API Key for job scoring (get it from https://console.groq.com/)

# Gmail credentials for email notifications
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Telegram bot credentials for notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Google Sheets configuration for exporting
GOOGLE_SHEETS_CRED_FILE=credentials.json
GOOGLE_SHEET_NAME=JobBot_Output
